---
interface Props {
  size?: number;
  rotating?: boolean;
}
const { size = 48, rotating = false } = Astro.props;

// Mapa pixel de la Tierra (16x16)
// b = outline · o = ocean claro · O = ocean oscuro · g = land claro · G = land oscuro · w = cloud
const pixels = [
  "....bbbbbbbb....",
  "..bbooogggookb..",
  ".booGgggoggooOb.",
  "bogGG.ggooggooOb",
  "boGG..ggogGGoooO",
  "boogggooogGGoook",
  "bgggggooogggoook",
  "bggg.ggoooogoooO",
  "boogggogggooGOOb",
  "bogggggoogGGGOOb",
  ".bogggooogGGoOb.",
  ".boooogggoooOOb.",
  "..bOooooooOOOb..",
  "...bbOOOooOOb...",
  ".....bbbbbb.....",
  "................",
];

const COLORS: Record<string, string> = {
  b: "#050a14",
  o: "#2a5ea0",
  O: "#13356a",
  g: "#3bb06e",
  G: "#1e7a4a",
  w: "#ffffff",
};

type Cell = { x: number; y: number; fill: string };
const cells: Cell[] = [];
pixels.forEach((row, y) => {
  [...row].forEach((ch, x) => {
    if (ch !== "." && COLORS[ch]) cells.push({ x, y, fill: COLORS[ch] });
  });
});

const width = pixels[0].length;
const height = pixels.length;
---

<div class:list={["earth-wrap", { rotating }]} style={`--earth-size:${size}px`}>
  <div class="earth-orbit" aria-hidden="true"></div>
  <svg
    viewBox={`0 0 ${width} ${height}`}
    shape-rendering="crispEdges"
    class="earth-svg"
    aria-hidden="true"
  >
    {cells.map((c) => (
      <rect x={c.x} y={c.y} width="1" height="1" fill={c.fill} />
    ))}
    <!-- Cloud highlights sobre el mapa -->
    <rect x="4" y="3" width="2" height="1" fill="#ffffff" opacity="0.55" />
    <rect x="5" y="4" width="1" height="1" fill="#ffffff" opacity="0.4" />
    <rect x="12" y="11" width="2" height="1" fill="#ffffff" opacity="0.4" />
  </svg>
</div>

<style>
  .earth-wrap {
    --earth-size: 48px;
    width: var(--earth-size);
    height: var(--earth-size);
    position: relative;
    display: inline-grid;
    place-items: center;
    filter: drop-shadow(0 0 10px rgba(59, 160, 255, 0.55));
  }

  .earth-svg {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    position: relative;
    z-index: 2;
  }

  .earth-wrap.rotating .earth-svg {
    animation: earth-spin 14s linear infinite;
  }

  @keyframes earth-spin {
    0% { transform: translateX(0); }
    100% { transform: translateX(0); }
  }

  .earth-orbit {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px dashed rgba(59, 255, 142, 0.25);
    animation: orbit-spin 8s linear infinite;
    z-index: 1;
  }
  .earth-orbit::after {
    content: "";
    position: absolute;
    top: -3px;
    left: 50%;
    width: 5px;
    height: 5px;
    background: var(--accent);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 8px var(--accent);
  }

  @keyframes orbit-spin {
    to { transform: rotate(360deg); }
  }
</style>
